# Clerk publishable key (from the Clerk dashboard)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Backend base URL (NO trailing slash, NO /api).
# Local dev can omit this (defaults to http://localhost:5000).
# In production (Vercel) set this to your Render backend URL, e.g.:
# VITE_API_URL=https://groove-backend.onrender.com
VITE_API_URL=http://localhost:5000
