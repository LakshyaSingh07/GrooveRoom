# Server
# On Render, PORT is provided automatically — no need to set it there.
PORT=5000
NODE_ENV=development

# Frontend origin allowed by CORS / Socket.io.
# Local dev defaults to http://localhost:3000.
# In production (Render) set this to your Vercel frontend URL, e.g.:
# CLIENT_URL=https://grooveroom.vercel.app
CLIENT_URL=http://localhost:3000

# Database
MONGODB_URI=your_mongodb_connection_string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Clerk
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Admin (email of the user who gets admin access)
ADMIN_EMAIL=you@example.com
